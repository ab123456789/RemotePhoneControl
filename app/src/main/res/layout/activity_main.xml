<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rpc_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RemotePhoneControl"
            android:textColor="@color/rpc_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="一个软件内同时支持被控端与控制端。被控端需要 root，控制端不需要 root，支持 IPv4 / IPv6 连接、画质调节与远程操作。"
            android:textColor="@color/rpc_muted"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStartAgent"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="启动被控端服务" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnStopAgent"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="停止被控端服务" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCopyLocalAddress"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="复制本机地址" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnCopyLocalCode"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="复制访问码" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCopyConnectionInfo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="复制完整连接信息" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="控制端"
            android:textColor="@color/rpc_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFFFF"
            android:hint="http://192.168.1.8:19876"
            android:inputType="textUri"
            android:padding="14dp"
            android:textColor="@color/rpc_text"
            android:textColorHint="@color/rpc_muted" />

        <EditText
            android:id="@+id/editAccessCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFFFF"
            android:hint="访问码"
            android:inputType="number"
            android:padding="14dp"
            android:textColor="@color/rpc_text"
            android:textColorHint="@color/rpc_muted" />

        <Button
            android:id="@+id/btnUseLocalAgent"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="使用本机被控地址" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFetchStatus"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="连通检查" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnFetchScreen"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="刷新画面" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="画质"
                android:textColor="@color/rpc_text" />

            <SeekBar
                android:id="@+id/seekQuality"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="70"
                android:progress="35" />

            <TextView
                android:id="@+id/textQuality"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="60"
                android:textColor="@color/rpc_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnWidthLow"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="低清" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnWidthMedium"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="中清" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnWidthHigh"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="高清" />
        </LinearLayout>

        <TextView
            android:id="@+id/textWidthPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="当前宽度：720"
            android:textColor="@color/rpc_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAutoRefresh"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="开启自动刷新" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnSwipeUp"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="上滑" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRefresh1s"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="1秒" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnRefresh2s"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="2秒" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnRefresh4s"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="4秒" />
        </LinearLayout>

        <TextView
            android:id="@+id/textRefreshPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="自动刷新：2秒"
            android:textColor="@color/rpc_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSwipeLeft"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="左滑" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnSwipeDown"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="下滑" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnSwipeRight"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="右滑" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imageScreen"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:background="#FF111827"
            android:contentDescription="远程画面"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="点画面会按当前图片比例映射成一次 tap。"
            android:textColor="@color/rpc_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="方向控制"
            android:textColor="@color/rpc_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnKeyUp"
                android:layout_width="72dp"
                android:layout_height="52dp"
                android:text="↑" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnKeyLeft"
                    android:layout_width="72dp"
                    android:layout_height="52dp"
                    android:text="←" />

                <Space android:layout_width="12dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnKeyEnter"
                    android:layout_width="72dp"
                    android:layout_height="52dp"
                    android:text="OK" />

                <Space android:layout_width="12dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnKeyRight"
                    android:layout_width="72dp"
                    android:layout_height="52dp"
                    android:text="→" />
            </LinearLayout>

            <Button
                android:id="@+id/btnKeyDown"
                android:layout_width="72dp"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="↓" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnKeyHome"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Home" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnKeyBack"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Back" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnKeyRecent"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Recent" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnKeyMenu"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Menu" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnKeyPower"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Power" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnKeyVolumeUp"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="音量+" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnKeyVolumeDown"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="音量-" />
        </LinearLayout>

        <EditText
            android:id="@+id/editRemoteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFFFF"
            android:hint="发送到远程手机的文本"
            android:padding="14dp"
            android:textColor="@color/rpc_text"
            android:textColorHint="@color/rpc_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPasteClipboard"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="粘贴本机剪贴板" />

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <Button
                android:id="@+id/btnClearText"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="清空文本" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSendText"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="发送文本" />

        <TextView
            android:id="@+id/textOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFFFF"
            android:padding="16dp"
            android:text="项目骨架已初始化，下一步开始接入远控协议与截图/输入能力。"
            android:textColor="@color/rpc_text"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>
