<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rpc_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RemotePhoneControl"
            android:textColor="@color/rpc_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="一个软件内同时支持被控端与控制端。被控端需要 root，控制端不需要 root，支持 IPv4 / IPv6 连接、画质调节与远程操作。"
            android:textColor="@color/rpc_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnStartAgent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="启动被控端服务" />

        <Button
            android:id="@+id/btnOpenController"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="打开控制台（开发中）" />

        <TextView
            android:id="@+id/textOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFFFF"
            android:padding="16dp"
            android:text="项目骨架已初始化，下一步开始接入远控协议与截图/输入能力。"
            android:textColor="@color/rpc_text"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>
